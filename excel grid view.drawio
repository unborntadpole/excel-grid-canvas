  <diagram name="Page-1" id="9_pPY9_3Xk40X9bsecBG">
    <mxGraphModel dx="4938" dy="2256" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n    %% Core Architecture (src/)\n    class Script {\n        &lt;&lt;Main Entry Point&gt;&gt;\n        • Boots up the application.\n        • Holds global application constants.\n    }\n    class GridApplication {\n        &lt;&lt;Main Application Context&gt;&gt;\n        • Provides outer application wrapper.\n        • Coordinates high-level event handlers.\n        • Spawns the central grid subsystem.\n    }\n    class Grid {\n        • Acts as the primary system coordinator.\n        • Wires data, rendering, selections, and inputs.\n        • Mediates communication between all sub-modules.\n    }\n    class GridRenderer {\n        &lt;&lt;Visual Layer&gt;&gt;\n        • Handles canvas drawing logic.\n        • Renders the spreadsheet grid and text headers.\n        • Draws active selection bounds and focal highlights.\n    }\n    class Datastore {\n        &lt;&lt;Data Layer&gt;&gt;\n        • Safely isolates and houses cell value matrices.\n        • Records explicit row heights and column widths.\n    }\n\n    %% Data Models (src/cell.ts)\n    class Cell {\n        • Models individual cell indices and values.\n    }\n    class CellRange {\n        • Defines a bounded block of coordinate positions.\n    }\n    class Selection {\n        • Tracks currently active cells and grouped zones.\n    }\n\n    %% Keyboard Inputs (src/eventhandlers/keyboard/)\n    class KeyboardController {\n        • Centralizes and maps all physical key listeners.\n    }\n    class CellEditing_Keyboard {\n        • Processes keystroke triggers to enter/exit edit states.\n    }\n    class Selection_Keyboard {\n        • Translates directional arrow keys into range navigation.\n    }\n    class CopyPaste_Keyboard {\n        • Catches hotkeys to trigger clipboard replication workflows.\n    }\n    class ImportJson_Keyboard {\n        • Evaluates key combinations aimed at external file loads.\n    }\n    class UndoRedo_Keyboard {\n        • Translates history rollback keys into action requests.\n    }\n\n    %% Mouse Inputs (src/eventhandlers/mouse/)\n    class MouseController {\n        • Centralizes and maps physical pointing device listeners.\n    }\n    class ColResize_Mouse {\n        • Interprets boundary dragging to adjust column spacing.\n    }\n    class RowResize_Mouse {\n        • Interprets boundary dragging to adjust row spacing.\n    }\n    class CellSelection_Mouse {\n        • Manages click-and-drag mechanics to group cells.\n    }\n    class ColHeaderSelection_Mouse {\n        • Translates header clicks into full-column focus flags.\n    }\n    class RowHeaderSelection_Mouse {\n        • Translates header clicks into full-row focus flags.\n    }\n\n    %% Miscellaneous Inputs &amp; Editing Helpers\n    class MiscListeners {\n        • Manages window resizing, layout scrolling, or file changes.\n    }\n    class EditingHelper {\n        • Safely flips a cell between view and interaction modes.\n    }\n\n    %% Commands Pattern (src/Command/)\n    class CommandsHandler {\n        • Tracks structural forward and backward state history.\n    }\n    class TypeAction {\n        • Encapsulates explicit text modifications for execution/rollback.\n    }\n    class RowColumnResize {\n        • Encapsulates physical width/height transformations.\n    }\n    class RederJson {\n        • Encapsulates external formatting payloads to update state.\n    }\n\n    %% Utilities (src/utils/)\n    class Generator {\n        • Serves mock structural data if loading dependencies fail.\n    }\n    class RowColumn {\n        • Synchronizes underlying dimensional metrics in memory.\n    }\n    class FetchFromJson {\n        • Extracts external payload structures for data integration.\n    }\n    class SelectionFunctions {\n        • Processes aggregations like sums, means, and basic metrics.\n    }\n    class CopyPaste_Util {\n        • Controls deep copying of coordinate maps and layout shifting.\n    }\n    class Formulae {\n        • Decodes string statements to process structural expressions.\n    }\n\n    %% Structural Mappings\n    Script --&gt; GridApplication\n    GridApplication --&gt; Grid\n    Grid --&gt; GridRenderer\n    Grid --&gt; Datastore\n    Grid --&gt; KeyboardController\n    Grid --&gt; MouseController\n    Grid --&gt; MiscListeners\n\n    Selection *-- CellRange\n    CellRange *-- Cell\n    Datastore o-- Cell\n\n    KeyboardController --&gt; CellEditing_Keyboard\n    KeyboardController --&gt; Selection_Keyboard\n    KeyboardController --&gt; CopyPaste_Keyboard\n    KeyboardController --&gt; ImportJson_Keyboard\n    KeyboardController --&gt; UndoRedo_Keyboard\n\n    MouseController --&gt; ColResize_Mouse\n    MouseController --&gt; RowResize_Mouse\n    MouseController --&gt; CellSelection_Mouse\n    MouseController --&gt; ColHeaderSelection_Mouse\n    MouseController --&gt; RowHeaderSelection_Mouse\n\n    CellEditing_Keyboard --&gt; EditingHelper\n    CellSelection_Mouse --&gt; EditingHelper\n    CommandsHandler --&gt; TypeAction\n    CommandsHandler --&gt; RowColumnResize\n    CommandsHandler --&gt; RederJson\n\n&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="2CFcPCh069Gphk5dXFSQ-272">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=10;" vertex="1">
            <mxGeometry height="1466" width="4166" as="geometry" />
          </mxCell>
        </UserObject>
